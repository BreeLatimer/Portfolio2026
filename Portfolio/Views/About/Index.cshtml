@{
    ViewData["Title"] = "About Me";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center mb-4">
            <h1 class="display-4 fw-bold text-dark">Hello, I'm Bree!</h1>
            <p class="lead text-secondary fs-4">Software Development Engineer in Test (SDET) II</p>
            <hr class="my-4" />
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-3 text-primary">My Engineering Journey</h3>
            <p class="text-muted">
                Holding a Bachelor's degree in Computer Science, I am deeply passionate about writing high-quality, production-grade code and building complex automated test frameworks. I approach software development with a rigorous <strong>Test-Driven Development (TDD)</strong> methodology, ensuring applications are stable, optimized, and ready to scale.
            </p>

            <h3 class="mt-4 mb-3 text-primary">Core Skillsets & Tools</h3>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-dark fs-6 px-3 py-2">C# / .NET 10</span>
                <span class="badge bg-primary fs-6 px-3 py-2">XUnit / NUnit</span>
                <span class="badge bg-info text-dark fs-6 px-3 py-2">Playwright E2E</span>
                <span class="badge bg-success fs-6 px-3 py-2">Docker Containers</span>
                <span class="badge bg-secondary fs-6 px-3 py-2">GitHub Actions CI/CD</span>
            </div>
        </div>
    </div>
</div>